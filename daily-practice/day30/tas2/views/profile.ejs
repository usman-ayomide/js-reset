<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
</head>
<body>
    <% if(isAdmin) { %>
        <p>Admin User: <%= name %></p>
    <% } else { %>
        <p>Regular User</p>
    <% } %>

    <% if(score > 80) { %>
        <p>High Achiever</p>
    <% } else { %>
        <p>Keep Going</p>
    <% } %>
</body>
</html>